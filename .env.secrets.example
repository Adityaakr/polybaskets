# Shared signer secret for both contest-bot and settler-bot.
# Set exactly one of these values in your untracked local secrets file.
# Railway should prefer SETTLER_SEED. SETTLER_SEED_FILE is intended for local/docker flows.

SETTLER_SEED=
SETTLER_SEED_FILE=

# Dedicated signer secret for bet-quote-service.
# This must NOT reuse SETTLER_SEED.
# Railway should prefer BET_QUOTE_SIGNER_SEED. BET_QUOTE_SIGNER_SEED_FILE is for local/docker if you mount a file.

BET_QUOTE_SIGNER_SEED=
BET_QUOTE_SIGNER_SEED_FILE=
