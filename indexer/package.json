{
  "name": "polybaskets-daily-contest-indexer",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "rm -rf lib && tsc -p tsconfig.json",
    "processor": "node lib/main.js",
    "serve": "node lib/api.js",
    "migration:generate": "npm run build && npx typeorm migration:generate -d lib/model/dataSource.js db/migrations/$NAME",
    "migration:run": "typeorm migration:run -d lib/model/dataSource.js"
  },
  "dependencies": {
    "@gear-js/api": "^0.43.0",
    "@polkadot/api": "^16.4.3",
    "@polkadot/api-augment": "^16.4.3",
    "@subsquid/logger": "^1.4.1",
    "@subsquid/substrate-processor": "^8.6.0",
    "@subsquid/substrate-runtime": "^2.0.1",
    "@subsquid/typeorm-store": "^1.5.1",
    "@subsquid/util-internal-hex": "^1.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "pg": "8.12.0",
    "postgraphile": "^4.14.1",
    "postgraphile-plugin-connection-filter": "^2.3.0",
    "reflect-metadata": "^0.2.2",
    "sails-js": "^0.4.3",
    "sails-js-parser": "^0.4.3",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "typescript": "^5.5.2"
  }
}
