type DailyContestConfig = struct {
  admin_role: actor_id,
  settler_role: actor_id,
  daily_reward: u128,
  grace_period_ms: u64,
};

type WinnerInput = struct {
  account: actor_id,
  realized_profit: i128,
};

type ContestDay = struct {
  day_id: u64,
  status: DayStatus,
  winners: vec WinnerPayout,
  total_reward: u128,
  settled_at: u64,
  settled_by: actor_id,
  result_hash: [u8, 32],
  evidence_hash: [u8, 32],
};

type DayStatus = enum {
  Settled,
  NoWinner,
};

type WinnerPayout = struct {
  account: actor_id,
  realized_profit: i128,
  reward: u128,
};

type DailyContestError = enum {
  Unauthorized,
  InvalidConfig,
  InvalidFundingAmount,
  DayNotClosed,
  DayAlreadySettled,
  DayNotFound,
  TooManyWinners,
  WinnersNotSorted,
  DuplicateWinner,
  WinnerProfitMismatch,
  InsufficientRewardPool,
  TransferFailed,
  MathOverflow,
  InvalidPageSize,
  ValueNotAllowed,
  EventEmitFailed,
};

type Pagination = struct {
  offset: u32,
  limit: u32,
};

constructor {
  New : (config: DailyContestConfig);
};

service DailyContest {
  Fund : () -> u128;
  SetAdminRole : (admin_role: actor_id) -> null;
  SetConfig : (config: DailyContestConfig) -> null;
  SetDailyReward : (daily_reward: u128) -> null;
  SetGracePeriod : (grace_period_ms: u64) -> null;
  SetRoles : (admin_role: actor_id, settler_role: actor_id) -> null;
  SetSettlerRole : (settler_role: actor_id) -> null;
  SettleDay : (day_id: u64, winners: vec WinnerInput, result_hash: [u8, 32], evidence_hash: [u8, 32]) -> null;
  WithdrawFunds : (to: actor_id, amount: u128) -> u128;
  query GetConfig : () -> DailyContestConfig;
  query GetDay : (day_id: u64) -> result (ContestDay, DailyContestError);
  query GetDayCount : () -> u64;
  query GetRewardPool : () -> u128;
  query ListDays : (query: Pagination) -> vec ContestDay;

  events {
    Funded: struct {
      from: actor_id,
      amount: u128,
      reward_pool: u128,
    };
    DaySettled: struct {
      day_id: u64,
      winner_count: u32,
      total_reward: u128,
      settled_at: u64,
      result_hash: [u8, 32],
      evidence_hash: [u8, 32],
    };
    WinnerPaid: struct {
      day_id: u64,
      winner: actor_id,
      realized_profit: i128,
      reward: u128,
    };
    ConfigUpdated: struct {
      config: DailyContestConfig
    };
    FundsWithdrawn: struct {
      to: actor_id,
      amount: u128,
      reward_pool: u128,
    };
  }
};

