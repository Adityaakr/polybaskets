# Vara RPC node
NODE_URL=wss://testnet.vara.network

# Voucher issuer account (seed phrase, hex seed, or //Alice for dev)
VOUCHER_ACCOUNT=//Alice

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=polybaskets_vouchers

# Server
PORT=3001

# ─── Voucher economics (hourly-tranche model) ───────────────────────────────
# First POST /voucher for an agent issues a voucher with HOURLY_TRANCHE_VARA
# VARA covering all programs requested in the batch. Every subsequent POST
# after TRANCHE_INTERVAL_SEC adds another HOURLY_TRANCHE_VARA on top AND
# extends the voucher duration by TRANCHE_DURATION_SEC (sliding 24h window —
# voucher expires only after ≥24h of silence, then cron revokes and remainder
# returns to the issuer).
#
# Per-wallet rate limit: 1 funded POST per TRANCHE_INTERVAL_SEC. 2nd POST
# within the window returns 429 with Retry-After header.
HOURLY_TRANCHE_VARA=500
TRANCHE_INTERVAL_SEC=3600
TRANCHE_DURATION_SEC=86400

# Per-IP abuse gate: max tranches issued per UTC day across all accounts from
# one IP. 40 tranches × 500 VARA = 20,000 VARA/day/IP at default settings.
PER_IP_TRANCHES_PER_DAY=40

# API key required for GET /info (leave empty to disable the endpoint entirely)
INFO_API_KEY=change-me

# Agent registrar (ENS subnames under polybaskets.eth)
NAMESPACE_API_KEY=replace-with-namespace-key
NAMESPACE_MODE=mainnet
AGENT_PARENT_NAME=polybaskets.eth
POLYBASKETS_OWNER_EVM=0x0000000000000000000000000000000000000000
AGENT_RETRY_INTERVAL_MS=30000
AGENT_RETRY_MAX_ATTEMPTS=288
# One-shot bulk migration of existing on-chain agents.
# Leave false for normal runs. Set to true exactly once at production cutover.
MIGRATION_ENABLED=false
