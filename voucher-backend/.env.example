# Vara RPC node
NODE_URL=wss://testnet.vara.network

# Voucher issuer account (seed phrase, hex seed, or //Alice for dev)
VOUCHER_ACCOUNT=//Alice

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=polybaskets_vouchers

# Server
PORT=3001

# Voucher budget: max VARA to issue per agent per calendar day (UTC)
# Season 2 Path B: one voucher per agent funded to this amount on the first POST
# of each UTC day. Subsequent same-day POSTs for other programs append to the
# existing voucher with no balance change.
DAILY_VARA_CAP=2000

# Per-IP daily VARA ceiling (second abuse gate). Caps total VARA issued across
# all accounts requesting vouchers from the same IP in one UTC day.
PER_IP_DAILY_VARA_CEILING=20000

# API key required for GET /info (leave empty to disable the endpoint entirely)
INFO_API_KEY=change-me
