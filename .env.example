# Local Postgres / GraphQL exposure
DB_NAME=polybaskets_indexer
DB_USER=postgres
DB_PASS=REPLACE_WITH_LOCAL_DB_PASSWORD
POSTGRES_PORT=5432
INDEXER_GQL_PORT=4350
BET_QUOTE_SERVICE_PORT=4360
INDEXER_GRAPHIQL_ENABLED=true
FRONTEND_URLS=http://localhost:8080,http://127.0.0.1:8080

# Shared chain/indexer source configuration
VARA_ARCHIVE_URL=REPLACE_WITH_ARCHIVE_URL
VARA_RPC_URL=REPLACE_WITH_RPC_URL
VARA_RPC_RATE_LIMIT=20
VARA_FROM_BLOCK=REPLACE_WITH_DEPLOY_BLOCK

# Program ids
BASKET_MARKET_PROGRAM_ID=REPLACE_WITH_BASKET_MARKET_PROGRAM_ID
BET_LANE_PROGRAM_ID=REPLACE_WITH_BET_LANE_PROGRAM_ID
DAILY_CONTEST_PROGRAM_ID=REPLACE_WITH_DAILY_CONTEST_PROGRAM_ID

# Daily contest read side / settlement
CONTEST_GRACE_PERIOD_MS=1800000
CONTEST_BOT_POLL_INTERVAL_MS=30000

# Basket settlement bot
SETTLER_BOT_POLL_INTERVAL_MS=30000
SETTLER_BOT_FINALIZE_ENABLED=true
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
BET_QUOTE_TTL_MS=30000
BET_QUOTE_BINDING_PREFIX=BetLaneQuoteV1

# Frontend endpoints
VITE_INDEXER_GRAPHQL_ENDPOINT=http://localhost:4350/graphql
VITE_BET_QUOTE_SERVICE_URL=http://127.0.0.1:4360

# Shared bot secret lives outside this template.
# Use .env.secrets and set exactly one of:
#   SETTLER_SEED=
#   SETTLER_SEED_FILE=

# Dedicated bet quote signer secret also lives outside this template.
# Use .env.secrets and set exactly one of:
#   BET_QUOTE_SIGNER_SEED=
#   BET_QUOTE_SIGNER_SEED_FILE=
